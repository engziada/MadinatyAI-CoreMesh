{
  "name": "core-hub",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/core-hub/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/core-hub/tsconfig.app.json && tsc-alias -p apps/core-hub/tsconfig.app.json"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/core-hub/src/main.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint \"apps/core-hub/**/*.ts\"" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "jest --selectProjects unit" }
    }
  },
  "tags": ["scope:app", "type:app"]
}
