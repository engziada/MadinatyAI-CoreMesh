# ──────────────────────────────────────────────────────────────
# MadinatyAI Ecosystem Hub — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Comma-separated CORS origins
# Include the Souk ElKanto frontend origin (:3001) or the browser will block its API calls.
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Root domain used to parse tenant subdomains (e.g. souq.madinatyai.com)
ROOT_DOMAIN=madinatyai.com

# ── PostgreSQL (pgvector enabled) ──────────────────────────────
# Default search schema is the shared core schema.
DATABASE_URL=postgresql://madinaty:madinaty@localhost:5432/madinatyai?schema=core

# ── Redis (events / cache / rate-limit) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to true for managed Redis (Upstash, ElastiCache) — wraps the BullMQ
# connection in TLS. Leave false for local Docker Redis on dev.
REDIS_TLS=false

# ── Hybrid AI routing ──────────────────────────────────────────
# Local inference (COMPLEXITY_LOW)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_MS=20000
# Cloud inference (COMPLEXITY_HIGH)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBED_MODEL=text-embedding-004

# ── KYC encryption (AES-256-GCM) ───────────────────────────────
# 32-byte key, hex-encoded (64 hex chars). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KYC_ENCRYPTION_KEY=
# Storage driver: local | s3  (MVP = local)
KYC_STORAGE_DRIVER=local
KYC_STORAGE_LOCAL_PATH=./storage/kyc

# ── Trust score tuning ─────────────────────────────────────────
TRUST_SCORE_BASE=100
TRUST_SCORE_BAN_THRESHOLD=20

# ── Cloudflare R2 (Souk ElKanto photo storage, Phase B) ────────
# Leave blank in dev — the photo-upload-url endpoint will return 503.
# Account-scoped: https://<account>.r2.cloudflarestorage.com
KANTO_R2_ENDPOINT=
KANTO_R2_ACCESS_KEY_ID=
KANTO_R2_SECRET=
KANTO_R2_BUCKET=
KANTO_R2_PUBLIC_BASE=
KANTO_R2_REGION=auto
KANTO_R2_PRESIGN_TTL_SECONDS=300

# ── Auth / JWT (Phase A) ───────────────────────────────────────
# JWT signing secret. Generate a long random value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=dev-only-secret-replace-me-32chars-min-aaaa
# R-11 F-16: shortened from 7d → 24h. Once refresh-token rotation lands
# (deferred F-15 / F-16 full fix), drop to 30m for prod.
JWT_EXPIRES_IN=24h
# OTP TTL in seconds (default 5 min) and max wrong attempts before lockout
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Dev OTP bypass: when true (non-prod only), the code "000000" is accepted
# for any phone number — useful for FE development and e2e tests.
AUTH_DEV_BYPASS=true
AUTH_DEV_BYPASS_CODE=000000

# ── WAHA (WhatsApp HTTP API) ───────────────────────────────────
# Self-hosted WAHA instance for OTP delivery & offer notifications.
# Leave blank to disable WhatsApp delivery (falls back to dev console / SMS stub).
# WAHA_BASE_URL=https://waha.xee.run.place
# WAHA_API_KEY=your-waha-api-key
# WAHA_SESSION=default

# ── Production build identity (CI-injected) ────────────────────
# Populated by the .github/workflows/deploy-be.yml job at image build time.
# Surface via GET /api/v1/version for incident response + deploy smoke checks.
BE_GIT_SHA=
BE_BUILD_TIME=

# ── Production deployment notes (DO NOT use dev values in prod) ─
# In production env:
#   NODE_ENV=production
#   AUTH_DEV_BYPASS=false             ← CRITICAL: never enable in prod
#   JWT_SECRET=<48 random bytes>      ← rotate from dev value
#   KYC_ENCRYPTION_KEY=<32 random>    ← rotate from dev value
#   CORS_ORIGINS=https://kanto.madinatyai.com
#   DATABASE_URL=postgresql://...     ← managed Postgres (Supabase / Neon)
#   REDIS_HOST + REDIS_PORT + REDIS_PASSWORD  ← managed Redis (Upstash)
